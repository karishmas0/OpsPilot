# OpsPilot Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# Core
ENV=dev
LOG_LEVEL=INFO

# Database (SQLite for local dev, Postgres in Docker)
DATABASE_URL=sqlite:///./opspilot.db

# Cache
REDIS_URL=redis://localhost:6379/0

# RAG settings
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
VECTOR_INDEX_PATH=./artifacts/vector_index
RAG_TOP_K=6
# Score fusion weight: alpha * vector + (1-alpha) * BM25
HYBRID_ALPHA=0.6

# LLM provider: "mock" for testing, "ollama" for real inference
LLM_PROVIDER=mock
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M

# Anomaly detection model paths
ANOMALY_MODEL_PATH=./models/anomaly_model.pkl
ANOMALY_VOCAB_PATH=./artifacts/anomaly_vocab.json

# API / UI
API_BASE_URL=http://localhost:8000

# Auth (disabled by default)
ENABLE_AUTH=false
JWT_SECRET=change_me_to_a_random_string

# MLflow experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000
